TURBK_IMAGE=ghcr.io/tursom/turbk:latest
TURBK_PULL_POLICY=missing
GOPROXY=https://proxy.golang.org,direct
TURBK_VERSION=0.1.0-dev
TURBK_COMMIT=local
TURBK_BUILD_DATE=unknown
TURBK_HTTP_PORT=8080

# Application config is loaded from this YAML file. Create it with:
# cp deploy/server/config.example.yaml config.yaml
# Edit server.public_url, auth, paths, repository, scheduler, and retention there.
TURBK_CONFIG_FILE=./config.yaml

# Host-side bind mount locations. The container-side paths are configured in
# TURBK_CONFIG_FILE and should usually stay /var/lib/turbk/{state,repo,restore}.
TURBK_STATE_DIR=./data/state
TURBK_REPO_DIR=./data/repo
TURBK_RESTORE_DIR=./data/restore
