TURBK_AGENT_IMAGE=ghcr.io/tursom/turbk-agent:latest
TURBK_AGENT_PULL_POLICY=missing
GOPROXY=https://proxy.golang.org,direct
TURBK_AGENT_VERSION=0.1.0-dev
TURBK_AGENT_COMMIT=local
TURBK_AGENT_BUILD_DATE=unknown

TURBK_SERVER_URL=http://backup-server.example.com:8080
TURBK_AGENT_ID=agt_replace_me
TURBK_AGENT_SECRET=ags_replace_me

TURBK_AGENT_DAEMON=true
TURBK_AGENT_SOURCE_DIR=/srv/data
TURBK_AGENT_ROOTS=/srv/data
TURBK_AGENT_STATE_DIR=/var/lib/turbk-agent
TURBK_AGENT_STATE_HOST_DIR=./agent-state
TURBK_AGENT_CATALOG_BACKEND=hybrid
TURBK_AGENT_BACKUP_SCHEDULE="0 0 * * *"
TURBK_AGENT_EXCLUDES=
TURBK_AGENT_SKIP_PSEUDO_FS=true
